# Banjo environment variables
#
# Vite inlines only `import.meta.env.VITE_*` variables into the client bundle.
# Never store secrets, API keys, or private tokens in VITE_* variables.
# They are visible in the built JavaScript sent to browsers.
#
# Build-only variables (no VITE_ prefix) are safe:
#   BANJO_WEB_ONLY=true    — web-only build, excludes extension entrypoints
#   VITEST=true            — sets browser resolve conditions during tests

# BEACON protocol noticeboard addresses for serverless workspace signaling.
# These are public Algorand addresses, not secrets.
# VITE_BEACON_PROTOCOL_ADDRESS_MAINNET=
# VITE_BEACON_PROTOCOL_ADDRESS_TESTNET=
# VITE_BEACON_PROTOCOL_ADDRESS_LOCALNET=
